        <VBox fx:id="balde4" alignment="BOTTOM_CENTER" minHeight="250.0" minWidth="80.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #ffffff; -fx-border-width: 0 4 4 4; -fx-border-radius: 0 0 15 15; -fx-background-radius: 0 0 15 15;"/>
