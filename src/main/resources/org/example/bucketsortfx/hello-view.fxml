<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Polygon?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #1e1e1e;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.bucketsortfx.Controller">

    <VBox spacing="10.0" style="-fx-background-color: #2b2b2b; -fx-padding: 20; -fx-border-color: #444444; -fx-border-radius: 10; -fx-background-radius: 10;"
          AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="30.0">
        <Label fx:id="lblIndice" text="indice = ?" style="-fx-text-fill: #4af626; -fx-font-family: 'Courier New'; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="lblI" text="i = ?" style="-fx-text-fill: #4af626; -fx-font-family: 'Courier New'; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="lblJ" text="j = ?" style="-fx-text-fill: #4af626; -fx-font-family: 'Courier New'; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="lblK" text="k = ?" style="-fx-text-fill: #4af626; -fx-font-family: 'Courier New'; -fx-font-size: 20px; -fx-font-weight: bold;"/>
    </VBox>

    <VBox fx:id="codigoContainer" spacing="3.0" style="-fx-background-color: #2b2b2b; -fx-padding: 15; -fx-border-color: #444444; -fx-border-radius: 10; -fx-background-radius: 10;"
          AnchorPane.topAnchor="30.0" AnchorPane.rightAnchor="30.0"/>

    <HBox alignment="CENTER" spacing="40.0"
          AnchorPane.topAnchor="400.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="550.0">
        <Polygon fx:id="funil" points="0.0, 0.0, 120.0, 0.0, 100.0, 80.0, 20.0, 80.0" fill="#e67e22" stroke="#d35400" strokeWidth="4.0"/>
        <HBox fx:id="container" alignment="CENTER" spacing="0.0"/>
    </HBox>

    <HBox alignment="CENTER" spacing="30.0"
          AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="550.0">
        <VBox fx:id="balde0" alignment="BOTTOM_CENTER" minHeight="250.0" minWidth="80.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #ffffff; -fx-border-width: 0 4 4 4; -fx-border-radius: 0 0 15 15; -fx-background-radius: 0 0 15 15;"/>
        <VBox fx:id="balde1" alignment="BOTTOM_CENTER" minHeight="250.0" minWidth="80.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #ffffff; -fx-border-width: 0 4 4 4; -fx-border-radius: 0 0 15 15; -fx-background-radius: 0 0 15 15;"/>
